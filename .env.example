# Azure OpenAI Configuration
# Copy this file to .env and fill in your actual values

# GPT-5.2 Configuration
GPT52_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
GPT52_KEY=your-gpt52-api-key
GPT52_DEPLOYMENT=gpt-5.2-chat
GPT52_API_VERSION=2024-12-01-preview

# PHI-4 Configuration  
PHI4_ENDPOINT=https://your-resource-name.services.ai.azure.com/
PHI4_KEY=your-phi4-api-key
PHI4_DEPLOYMENT=phi-4-mini-reasoning
PHI4_API_VERSION=2024-05-01-preview